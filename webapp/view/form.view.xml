<mvc:View controllerName="fi18n.form.controller.form"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns="sap.m" height="100%"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:svm="sap.ui.comp.smartvariants" 
    core:require="{formatter: 'fi18n/form/model/formatter'}"> 
    <f:DynamicPage id="page">
        <f:title>
            <f:DynamicPageTitle id="_IDGenDynamicPageTitle1">
                <f:heading>
                    <Title id="_IDGenTitle" text="Form With Table - JSON model" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader id="_IDGenDynamicPageHeader">
                <f:content>
                    <fb:FilterBar id="filterbar" persistencyKey="myPersKey" search=".onSearchTop" useToolbar="false">
                        <fb:filterGroupItems>
                            <fb:FilterGroupItem id="_IDGenFilterGroupItem" name="Result" label="Result" groupName="FormGroup" visibleInFilterBar="true">
                                <fb:control>
                                    <MultiComboBox id="searchResult">
                                        <core:Item id="_IDGenItem" key="Pass" text="Pass"/>
                                        <core:Item id="_IDGenItem1" key="Fail" text="Fail"/>
                                    </MultiComboBox>
                                </fb:control>
                            </fb:FilterGroupItem>

                            <fb:FilterGroupItem id="_IDGenFilterGroupItem1" name="ID" label="ID" groupName="FormGroup" visibleInFilterBar="true">
                                <fb:control>
                                    <Input id="_IDGenInput" value="{form>/inIdS}" />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem id="_IDGenFilterGroupItem2" name="Name" label="Name" groupName="FormGroup" visibleInFilterBar="true">
                                <fb:control>
                                    <Input id="_IDGenInput1" value="{form>/inNameS}" />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem id="_IDGenFilterGroupItem3" name="Age" label="Age" groupName="FormGroup" visibleInFilterBar="true">
                                <fb:control>
                                    <Input id="_IDGenInput2" value="{form>/inAgeS}" />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem id="_IDGenFilterGroupItem4" name="Role" label="Role" groupName="FormGroup" visibleInFilterBar="true">
                                <fb:control>
                                    <Input id="_IDGenInput3" value="{form>/inRoleS}" />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem id="_IDGenFilterGroupItem5" name="Email" label="Email" groupName="FormGroup" visibleInFilterBar="true">
                                <fb:control>
                                    <Input id="_IDGenInput4" value="{form>/inEmailS}" />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem id="_IDGenFilterGroupItem6" name="Address" label="Address" groupName="FormGroup" visibleInFilterBar="true">
                                <fb:control>
                                    <Input id="_IDGenInput9" value="{form>/inAdressS}" />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem id="_IDGenFilterGroupItem7" name="Date of Birth" label="Date of Birth" groupName="FormGroup" visibleInFilterBar="true">
                                <fb:control>
                                    <DatePicker id="_IDGenDatePicker_DobS" value="{path: 'form>/inDobS', type: 'sap.ui.model.type.Date'}" displayFormat="dd-MMM-yyyy" />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem id="_IDGenFilterGroupItem8" name="Date of Submission" label="Date of Submission" groupName="FormGroup" visibleInFilterBar="true">
                                <fb:control>
                                    <DateTimePicker id="_IDGenDatePicker_DosS" value="{path: 'form>/inDosS', type: 'sap.ui.model.type.DateTime'}" displayFormat="dd/MM/yyyy HH:mm:ss" />
                                </fb:control>
                            </fb:FilterGroupItem>
                        </fb:filterGroupItems>
                    </fb:FilterBar>
                </f:content>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox id="_IDGenVBox" class="sapUiContentPadding">

                <form:SimpleForm id="_IDGenSimpleForm" width="100%" layout="ResponsiveGridLayout" editable="true" labelSpanL="3" labelSpanM="3" emptySpanL="4" emptySpanM="4" columnsL="1" columnsM="1" title="Fill The Details">
                    <form:content>
                        <Label id="_IDGenLabel" required="true" text="Name" />
                        <Input id="_IDGenInput5" value="{form>/inName}" maxLength="15"/>

                        <Label id="_IDGenLabel1" text="Age"/>
                        <Input id="_IDGenInput6" value="{form>/inAge}" maxLength="2" />

                        <Label id="_IDGenLabel2" text="Role"/>
                        <Input id="_IDGenInput7" value="{form>/inRole}" maxLength="5"/>

                        <Label id="_IDGenLabel3" required="true" text="Email"/>
                        <Input id="_IDGenInput8" value="{form>/inEmail}" maxLength="15" type="Email"/>

                        <Label id="_IDGenLabel4" text="Address"/>
                        <VBox id="_IDGenVBox1">
                            <VBox id="addressContainer" items="{form>/inaddresses}">
                                <items>
                                    <HBox id="_IDGenHBox" alignItems="Center">
                                        <TextArea id="_IDGenTextArea" value="{form>value}" rows="4" width="300px" />
                                        <Button id="_IDGenButton" icon="sap-icon://delete" press=".onRemoveAddress" />
                                    </HBox>
                                </items>
                            </VBox>
                            <Button id="_IDGenButton1" icon="sap-icon://add" press=".onAddAddress" />
                        </VBox>

                        <Label id="_IDGenLabel7" text="Date of Birth"/>
                        <!-- <DatePicker id="_IDGenDatePicker_Dos" value="{form>/inDob}" displayFormat="dd-MMM-yyyy" valueFormat="dd-MMM-yyyy" /> -->

                        <DatePicker id="_IDGenDatePicker_Dob" value="{path: 'form>/inDob', type: 'sap.ui.model.type.Date'}" displayFormat="dd-MMM-yyyy" />

                        <Label id="_IDGenLabel5" text="Result"/>
                        <Select id="_IDGenSelect" selectedKey="{form>/inResult}">
                            <core:ListItem id="_IDGenListItem" key="Pass" text="Pass" icon="sap-icon://accept" />
                            <core:ListItem id="_IDGenListItem1" key="Fail" text="Fail" icon="sap-icon://decline" />
                        </Select>

                        <Label id="_IDGenLabel8" text="Date and Time of Submission"/>
                        <!-- <DateTimePicker id="_IDGenDatePicker_Dos" value="{form>/inDos}" displayFormat="dd/MM/yyyy HH:mm:ss" valueFormat="dd/mm/yyyy','HH:mm:ss" /> -->

                        <DateTimePicker id="_IDGenDatePicker_Dos" value="{path: 'form>/inDos', type: 'sap.ui.model.type.DateTime'}" displayFormat="dd/MM/yyyy HH:mm:ss" />

                        <Label id="_IDGenLabel6" />
                        <Button id="_IDGenButton2" text="Submit" press=".onSubmit" type="Emphasized" width="150px"/>

                    </form:content>
                </form:SimpleForm>

                <VBox id="_IDGenVBox2" class="sapUiMediumMarginTop">
                    <Toolbar id="_IDGenToolbar">
                        <SearchField id="_IDGenSearchField" search=".onSearch" />
                        <Text id="_IDGenText" text="{form>/searchText}" />
                        <Button id="_IDGenButton3" icon="sap-icon://sorting-ranking" tooltip="Sorting Dialog Box" press=".handleOpenDialog"/>
                    </Toolbar>

                    <Table items="{form>/Table}" id="dataTable">
                        <columns>
                            <Column id="_IDGenColumn"><Text id="_IDGenText1" text="Result" /></Column>
                            <Column id="_IDGenColumn1"><Text id="_IDGenText2" text="ID" /></Column>
                            <Column id="_IDGenColumn2"><Text id="_IDGenText3" text="Name" /></Column>
                            <Column id="_IDGenColumn3"><Text id="_IDGenText4" text="Age" /></Column>
                            <Column id="_IDGenColumn4"><Text id="_IDGenText5" text="Role" /></Column>
                            <Column id="_IDGenColumn5"><Text id="_IDGenText6" text="Email" /></Column>
                            <Column id="_IDGenColumn6"><Text id="_IDGenText7" text="Address" /></Column>
                            <Column id="_IDGenColumn7"><Text id="_IDGenText15" text="Date of Birth" /></Column>
                            <Column id="_IDGenColumn8"><Text id="_IDGenText16" text="Date and Time of Submission" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem id="_IDGenColumnListItem">
                                <cells>
                                    <core:Icon id="_IDGenIcon" src="{= ${form>outResult} === 'Pass' ? 'sap-icon://accept' : 'sap-icon://decline'}" color="{= ${form>outResult} === 'Pass' ? 'Positive' : 'Negative'}"/>
                                    <Text id="_IDGenText8" text="{form>outId}" />
                                    <Text id="_IDGenText9" text="{form>outName}" />
                                    <Text id="_IDGenText10" text="{form>outAge}" />
                                    <Text id="_IDGenText11" text="{form>outRole}" />
                                    <Text id="_IDGenText12" text="{form>outEmail}" />
                                    <Text id="_IDGenText13" text="{form>outAddress}" wrapping="true" />
                                    
                                    <Text id="_IDGenText14" text="{
                                        path: 'form>outDob',
                                        formatter: 'formatter.formatDate'
                                    }" />
                                    <Text id="_IDGenText17" text="{
                                        path: 'form>outDos',
                                        formatter: 'formatter.formatDateTime'
                                    }" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                </VBox>

            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>
